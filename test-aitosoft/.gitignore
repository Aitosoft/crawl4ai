# Test outputs — don't commit large run artifacts.
# NOTE: ignore the *contents* (artifacts/*), not the dir (artifacts/) —
# git cannot re-include paths under a wholesale-excluded directory, so the
# !negations below only work with this form.
artifacts/*
reports/*

# Keep directory structure
!artifacts/.gitkeep
!reports/.gitkeep

# Allow deliberately-kept manual test results
!artifacts/manual/
!reports/manual/
