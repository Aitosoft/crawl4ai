# Test outputs — don't commit large run artifacts.
# NOTE: ignore the *contents* (artifacts/*), not the dir (artifacts/) —
# git cannot re-include paths under a wholesale-excluded directory, so the
# !negations below only work with this form.
artifacts/*
reports/*

# Keep directory structure
!artifacts/.gitkeep
!reports/.gitkeep

# Allow deliberately-kept results (copy them into keep/ by hand).
# Named keep/, NOT manual/ — test_site.py's default --version label is
# "manual", so routine default-label runs would otherwise become untracked
# noise here.
!artifacts/keep/
!reports/keep/
